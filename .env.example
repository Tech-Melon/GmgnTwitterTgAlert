# ==========================================
#  GmgnTwitterClaw 配置模板
#  复制此文件为 .env 并填入真实值
# ==========================================

# ---------- WebSocket 分发配置 ----------
# 鉴权 Token（建议使用 python -c "import secrets; print(secrets.token_urlsafe(32))" 生成）
WS_TOKEN=change-me-to-a-strong-token

# ---------- Telegram 推送配置 ----------
TG_BOT_TOKEN=123456789:ABCDefghIJKLmnopQRSTuvwxYZ123456789

# ---------- 飞书应用全局配置 (用于上传卡片原图) ----------
# 飞书企业自建应用凭证 (需要去飞书开发者后台开通 "获取与上传图片或文件" im:resource:upload 权限)
FEISHU_APP_ID=cli_xxxxxxxxxxxx
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# 大杂烩 / 默认频道（未命中任何路由分组时的兜底推送）
TG_ENABLE_DEFAULT=False
TG_CHANNEL_ID=-1001234567890

FEISHU_ENABLE_DEFAULT=False
FEISHU_WEBHOOK_DEFAULT=
FEISHU_SECRET_DEFAULT=

# ---------- 频道分组路由 ----------
# 规则：每个分组可同时发往 TG 和 飞书，共用 TG_ROUTING 的把控名单。
#   TG_ROUTING_<GROUP>    = handle1,handle2,...  逗号分隔的推特用户名（小写）
#   
#   TG_ENABLE_<GROUP>    = True/False  是否推送到该组 TG 频道
#   TG_CHANNEL_ID_<GROUP> = TG 频道 ID
#
#   FEISHU_ENABLE_<GROUP> = True/False 是否推送到该组飞书群
#   FEISHU_WEBHOOK_<GROUP>= 飞书群自定义机器人 Webhook URL
#   FEISHU_SECRET_<GROUP> = 飞书签名密钥 (Secret)

# 币安创始系
TG_ROUTING_BINANCE=cz_binance,heyibinance,cz,heyi
TG_ENABLE_BINANCE=True
TG_CHANNEL_ID_BINANCE=-1001234567891
FEISHU_ENABLE_BINANCE=False
FEISHU_WEBHOOK_BINANCE=
FEISHU_SECRET_BINANCE=

# 马斯克专区
TG_ROUTING_MUSK=elonmusk
TG_ENABLE_MUSK=True
TG_CHANNEL_ID_MUSK=-1001234567892
FEISHU_ENABLE_MUSK=False
FEISHU_WEBHOOK_MUSK=
FEISHU_SECRET_MUSK=

# 附加过滤名单（一般留空即可，启用的路由分组里的 handle 会自动合并进来）
TG_FILTER_HANDLES=

# 币安广场账号声明（逗号分隔的用户名小写），用于 TG 分发器特殊处理链接预览
BINANCE_SQUARE_HANDLES=cz,heyi

# ---------- Webhook 推送配置（留空则禁用） ----------
WEBHOOK_URL=
WEBHOOK_SECRET=

# ---------- DeepSeek 翻译配置 ----------
# 用于推文自动翻译，留空则跳过翻译
DEEPSEEK_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
